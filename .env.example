GSV_API_KEY=your_google_street_view_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — only needed for the SAM 3 backend (Phase 3, --backend sam3).
# Get a token at https://huggingface.co/settings/tokens after accepting the
# license at https://huggingface.co/facebook/sam3.
HF_TOKEN=

# Optional — only needed for the Roboflow backend (Phase 3, --backend roboflow).
ROBOFLOW_API_KEY=
ROBOFLOW_WORKSPACE=
ROBOFLOW_PROJECT=
ROBOFLOW_VERSION=
